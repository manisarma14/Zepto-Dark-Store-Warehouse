# ================================================
# ZEPTO DARK STORE WAREHOUSE — ENVIRONMENT VARIABLES
# Copy this file to .env and fill in your values
# NEVER commit .env to GitHub
# ================================================

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=zepto_oms
POSTGRES_USER=zepto_user
POSTGRES_PASSWORD=zepto_pass

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_ZOOKEEPER_CONNECT=localhost:2181

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_ENDPOINT=http://localhost:9000
MINIO_BUCKET_BRONZE=bronze
MINIO_BUCKET_SILVER=silver
MINIO_BUCKET_GOLD=gold

# Airflow
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__CORE__FERNET_KEY=
AIRFLOW__CORE__LOAD_EXAMPLES=False
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=admin

# dbt
DBT_PROFILES_DIR=./dbt

# DuckDB
DUCKDB_PATH=./duckdb/zepto.duckdb

# Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
GRAFANA_PORT=3000

# Great Expectations
GE_DATA_DOCS_HOST=localhost
GE_DATA_DOCS_PORT=8080

# Snowflake (30 day trial only)
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_WAREHOUSE=
SNOWFLAKE_DATABASE=
SNOWFLAKE_SCHEMA=
SNOWFLAKE_ROLE=

# Slack Alerts
SLACK_WEBHOOK_URL=